<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Workflow">
    <mxGraphModel dx="1000" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1150" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="refactory: the refactoring workflow" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="700" height="40" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Every change stays behavior-preserving: net first, small steps, revert on red, ledger at the end" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontColor=#777777;" vertex="1" parent="1">
          <mxGeometry x="62" y="66" width="820" height="24" as="geometry" />
        </mxCell>

        <mxCell id="START" value="Refactor request&#xa;or you spot a smell" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="110" width="240" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ARM" value="Arm the guard&#xa;.refactory/guard.json = { net: pending }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="230" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="NET" value="Read the target&#xa;find or establish a safety net" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="340" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="DEC" value="Cheap low-risk net,&#xa;or purely mechanical?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="450" width="260" height="120" as="geometry" />
        </mxCell>

        <mxCell id="ASK" value="Ask the user, then wait&#xa;A. write tests   B. accept risk&#xa;C. defer   D. hybrid&#xa;(gate blocks source edits meanwhile)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="770" y="460" width="320" height="100" as="geometry" />
        </mxCell>
        <mxCell id="BUILD" value="Build the net (or run the exact tool)&#xa;then proceed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="620" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="RESOLVE" value="Net resolved  →  gate unblocks edits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="730" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="IDENT" value="Name the smells  →  look up the mechanics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="830" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="TRANS" value="Transform in small steps&#xa;test after each, revert on red" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="930" width="280" height="70" as="geometry" />
        </mxCell>

        <mxCell id="BACK" value="Spot a bug?&#xa;File it to backlog.md&#xa;not fixed now (two hats)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="925" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="FIX" value="Fix phase: /refactor fix&#xa;separate, on demand&#xa;fresh fixer per bug, highest risk first" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="1090" width="270" height="90" as="geometry" />
        </mxCell>

        <mxCell id="LEDGER" value="Write the discipline ledger&#xa;→ learnings.md" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="1050" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="STOPD" value="Stop hook:&#xa;ledger written?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="410" y="1150" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="DISARM" value="Disarm, delete guard.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="390" y="1310" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="END" value="Done: behavior preserved" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
